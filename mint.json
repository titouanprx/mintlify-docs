{
  "$schema": "https://mintlify.com/schema.json",
  "name": "LinkUp API",
  "baseUrl": "https://docs.linkupapi.com",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373",
    "anchors": {
      "from": "#0D9373",
      "to": "#07C983"
    }
  },
  "openapi": "./openapi.json",
  "api": {
    "baseUrl": "https://api.linkupapi.com",
    "auth": {
      "method": "bearer"
    }
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@linkup.com"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://dashboard.linkup.com"
  },
  "tabs": [
    {
      "name": "API Reference",
      "url": "api-reference"
    }
  ],
  "anchors": [
    {
      "name": "Documentation",
      "icon": "book-open-cover",
      "url": "https://docs.linkupapi.com"
    },
    {
      "name": "Community",
      "icon": "slack",
      "url": "https://linkupapi.com/community"
    }
  ],
  "navigation": [
    {
      "group": "Getting Started",
      "pages": [
        "introduction",
        "quickstart"
      ]
    },
    {
      "group": "API Reference",
      "pages": [
        "api-reference/introduction"
      ]
    },
    {
      "group": "Authentication",
      "pages": [
        "api-reference/linkup/Login/login",
        "api-reference/linkup/Login/verify"
      ]
    },
    {
      "group": "Companies",
      "pages": [
        "api-reference/linkup/Companies/search"
      ]
    },
    {
      "group": "People",
      "pages": [
        "api-reference/linkup/People/connect",
        "api-reference/linkup/People/connections",
        "api-reference/linkup/People/extract-contact"
      ]
    },
    {
      "group": "Posts",
      "pages": [
        "api-reference/linkup/posts/comment",
        "api-reference/linkup/posts/create",
        "api-reference/linkup/posts/extract",
        "api-reference/linkup/posts/like",
        "api-reference/linkup/posts/repost"
      ]
    }
  ],
  "footerSocials": {
    "twitter": "https://twitter.com/linkupapi",
    "github": "https://github.com/linkupapi",
    "linkedin": "https://linkedin.com/company/linkupapi"
  },
  "analytics": {
    "ga4": {
      "measurementId": "G-XXXXXXXXXX"
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "search": {
    "prompt": "Search the docs..."
  }
}