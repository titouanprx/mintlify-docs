{
  "$schema": "https://mintlify.com/schema.json",
  "name": "LinkUp API",
  "baseUrl": "https://docs.linkupapi.com",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373",
    "anchors": {
      "from": "#0D9373",
      "to": "#07C983"
    }
  },
  "openapi": "./openapi.json",
  "api": {
    "baseUrl": "https://api.linkupapi.com",
    "auth": {
      "method": "key",
      "name": "x-api-key",
      "inputPrefix": ""
    },
    "playground": {
      "mode": "show"
    }
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@linkup.com"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://dashboard.linkup.com"
  },
  "tabs": [
    {
      "name": "API Reference",
      "url": "api-reference"
    }
  ],
  "navigation": [
    {
      "group": "Getting Started",
      "pages": [
        "introduction",
        "quickstart"
      ]
    },
    {
      "group": "API Reference",
      "pages": [
        "api-reference/introduction"
      ]
    },
    {
      "group": "Statistiques",
      "pages": [
        "api-reference/linkup/Stats/linkedin-stats"
      ]
    },
    {
      "group": "Authentication",
      "pages": [
        "api-reference/linkup/Login/login",
        "api-reference/linkup/Login/verify"
      ]
    },
    {
      "group": "Profile",
      "pages": [
        "api-reference/linkup/Profile/me",
        "api-reference/linkup/Profile/info",
        "api-reference/linkup/Profile/contact"
      ]
    },
    {
      "group": "Companies",
      "pages": [
        "api-reference/linkup/Companies/info",
        "api-reference/linkup/Companies/search"
      ]
    },
    {
      "group": "Network",
      "pages": [
        "api-reference/linkup/Network/connect",
        "api-reference/linkup/Network/connections",
        "api-reference/linkup/Network/invitations",
        "api-reference/linkup/Network/accept-invitation"
      ]
    },
    {
      "group": "Messages",
      "pages": [
        "api-reference/linkup/Messages/send",
        "api-reference/linkup/Messages/inbox",
        "api-reference/linkup/Messages/conversation"
      ]
    },
    {
      "group": "Posts",
      "pages": [
        "api-reference/linkup/Posts/create",
        "api-reference/linkup/Posts/extract",
        "api-reference/linkup/Posts/like",
        "api-reference/linkup/Posts/comment",
        "api-reference/linkup/Posts/comments",
        "api-reference/linkup/Posts/repost",
        "api-reference/linkup/Posts/reactions"
      ]
    }
  ],
  
  "footerSocials": {
    "twitter": "https://twitter.com/linkupapi",
    "github": "https://github.com/linkupapi",
    "linkedin": "https://linkedin.com/company/linkupapi"
  },
  "analytics": {
    "ga4": {
      "measurementId": "G-XXXXXXXXXX"
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "search": {
    "prompt": "Search the docs..."
  }
}
