{
  "$schema": "https://mintlify.com/schema.json",
  "name": "LinkUp API",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "openapi": ["openapi.json"],
  "api": {
    "baseUrl": "https://api.linkup.com",
    "auth": {
      "method": "key",
      "name": "x-api-key",
      "inputPrefix": "Bearer"
    }
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@linkup.com"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://dashboard.linkup.com"
  },
  "anchors": [
    {
      "name": "Documentation",
      "icon": "book-open-cover",
      "url": "/docs"
    },
    {
      "name": "API Reference",
      "icon": "square-terminal",
      "url": "/api-reference"
    },
    {
      "name": "Blog",
      "icon": "newspaper",
      "url": "/blog"
    }
  ],
  "navigation": [
    {
      "group": "Get Started",
      "pages": [
        "introduction",
        "quickstart",
        "authentication"
      ]
    },
    {
      "group": "API Reference",
      "pages": [
        "api-reference/introduction"
      ]
    },
    {
      "group": "Endpoints",
      "pages": [
        {
          "group": "Authentication",
          "pages": ["api/auth/login", "api/auth/verify"]
        },
        {
          "group": "Profile",
          "pages": ["api/profile/extract-contact"]
        },
        {
          "group": "Posts",
          "pages": [
            "api/posts/extract",
            "api/posts/create",
            "api/posts/comment",
            "api/posts/like",
            "api/posts/repost"
          ]
        },
        {
          "group": "Search",
          "pages": ["api/search/people", "api/search/companies"]
        },
        {
          "group": "Network",
          "pages": ["api/network/connect", "api/network/connections"]
        }
      ]
    }
  ],
  "footerSocials": {
    "x": "https://twitter.com/linkupapi",
    "github": "https://github.com/linkupapi",
    "linkedin": "https://linkedin.com/company/linkupapi"
  }
}